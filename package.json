{
  "name": "fractalxr",
  "version": "0.8.1",
  "private": true,
  "type": "module",
  "description": "WebXR 3D fractal flame generator for the Meta Quest 3",
  "scripts": {
    "dev": "vite",
    "bake": "vite --config vite.bake.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  }
}
